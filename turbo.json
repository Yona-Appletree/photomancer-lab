{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["posts:build"],
      "outputs": ["public/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format:check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "posts:build": {
      "outputs": ["content/post/*.gen.md"]
    },
    "posts:check": {
      "outputs": ["content/post/*.gen.md"]
    },
    "test": {
      "dependsOn": ["posts:build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["posts:build"],
      "outputs": []
    },
    "validate": {
      "outputs": []
    }
  }
}
